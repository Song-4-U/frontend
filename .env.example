# =====================================================
# Frontend Environment Variables
# =====================================================
# - 이 파일은 템플릿입니다. 실제 값은 .env.local 에 작성하세요.
# - NEXT_PUBLIC_ 접두사가 붙은 변수만 브라우저에서 접근 가능합니다.
# - 비밀값(API 키 등)은 절대 NEXT_PUBLIC_ 접두사를 붙이지 마세요.

# core-api Base URL (프론트엔드가 호출하는 백엔드 주소)
# - 로컬 개발:    http://localhost:8080
# - 스테이징:     https://staging-api.song4u.example.com
# - 프로덕션:     https://api.song4u.example.com
NEXT_PUBLIC_CORE_API_BASE_URL=http://localhost:8080

# Mock API 사용 여부 (Phase 1 단계에서만 true 권장)
# - true:  MSW 또는 fixture 기반 mock 응답 사용
# - false: 실제 core-api 호출
NEXT_PUBLIC_USE_MOCK_API=true
